# Copy to `.env` in this folder. Required for local API + Prisma.

# --- Database (required) ---
DATABASE_URL="postgresql://user:password@localhost:5432/ace_truckers_erp?schema=public"

# --- JWT (recommended; dev fallback exists if unset) ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- HTTP server ---
PORT=3001
NODE_ENV=development

# CORS: origin of the Vite web app (default in main.ts is http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# --- Timezone (recommended for logs / date logic) ---
TZ=Asia/Manila

# --- Local file uploads (PODs, payslips, etc.) ---
# Relative to the API process cwd; directory is created as needed.
UPLOAD_PATH=uploads

# --- Optional: push notifications (FCM) ---
# Path to Firebase service account JSON, or leave unset to disable FCM.
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# --- Legacy / optional: S3-style object storage (not wired in all code paths) ---
# If your deployment uses MinIO or S3, set these to match your env.
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=ace-truckers-uploads
# S3_REGION=us-east-1
