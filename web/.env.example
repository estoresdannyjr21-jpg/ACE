# Copy to `.env` in this folder (optional). Vite reads `VITE_*` vars at build/dev time.

# Base URL for the API (no trailing slash).
# Local dev: use `/api` so the Vite dev server proxies to the Nest API (see vite.config.ts → http://localhost:3001).
VITE_API_URL=/api

# If you call the API directly (no proxy), e.g.:
# VITE_API_URL=http://localhost:3001

# Optional: JWT for development only (bypasses login in browser).
# Prefer logging in via the app UI; or set in DevTools:
#   sessionStorage.setItem('auth_token', 'YOUR_JWT')
# VITE_AUTH_TOKEN=
